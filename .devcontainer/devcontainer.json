{
  "name": "Zowe + Spring Boot (z/OS Dev)",
  "image": "mcr.microsoft.com/devcontainers/java:21",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    }
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y dbus libsecret-1-0 uuid-runtime && sudo dbus-uuidgen --ensure && npm install -g @zowe/cli",

  "customizations": {
    "vscode": {
      "extensions": [
        "vmware.vscode-boot-dev-pack",
        "redhat.java",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vscjava.vscode-gradle",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test",
        "vscjava.vscode-lombok",
        "zowe.vscode-extension-for-zowe",
        "github.copilot-chat",
        "vscode-icons-team.vscode-icons"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteEnv": {
    "ZOWE_CLI_NO_SECURE": "true",
    "ZOWE_OPT_NO_KEYRING": "true"
  },

  "forwardPorts": [8080]
}