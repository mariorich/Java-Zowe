{
  "name": "Java 21 + Spring + Zowe + Postgres",

  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspaces",

  "forwardPorts": [8080, 5432],

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y maven postgresql-client && npm install -g @zowe/cli",

  "customizations": {
    "vscode": {
      "extensions": [
        "vmware.vscode-boot-dev-pack",
        "redhat.java",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vscjava.vscode-gradle",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test",
        "vscjava.vscode-lombok",
        "zowe.vscode-extension-for-zowe",
        "github.copilot-chat",
        "vscode-icons-team.vscode-icons",
        "cweijan.vscode-postgresql-client2",
        "ibm.db2forzosdeveloperextension"
      ],
      "settings": {
      "zowe.useCredentialManager": false
      }
    }
  },

  "remoteEnv": {
    "ZOWE_CLI_NO_SECURE": "true",
    "ZOWE_OPT_NO_KEYRING": "true"
  }
}